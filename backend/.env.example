# Untuk pakai PostgreSQL (rekomendasi produksi), contoh:
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/kas_kkn
# Untuk testing cepat tanpa install PostgreSQL, biarkan kosong (otomatis pakai SQLite lokal)
DATABASE_URL=

JWT_SECRET_KEY=ganti-dengan-secret-key-acak
FLASK_ENV=development

# Untuk kirim notifikasi email saat bendahara menandai penggantian sudah dibayar.
# Gunakan Gmail App Password (myaccount.google.com/apppasswords), BUKAN password akun biasa.
# Kosongkan MAIL_USERNAME kalau tidak mau fitur email aktif (akan di-skip otomatis).
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
# Isi untuk testing: semua notifikasi email dikirim ke alamat ini, bukan ke
# email anggota yang sebenarnya. Kosongkan di produksi.
MAIL_TEST_OVERRIDE_TO=

# Untuk fitur input transaksi lewat chat Telegram. Buat bot lewat @BotFather
# di Telegram untuk dapat TELEGRAM_BOT_TOKEN dan TELEGRAM_BOT_USERNAME.
# Kosongkan TELEGRAM_BOT_TOKEN kalau tidak mau fitur ini aktif.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
# Kosongkan di dev lokal (bot otomatis pakai polling). Di Render, RENDER_EXTERNAL_URL
# sudah diisi otomatis sehingga bot pakai mode webhook tanpa perlu setting ini manual.
TELEGRAM_WEBHOOK_BASE_URL=
# Opsional, kalau kosong akan digenerate otomatis saat bot start.
TELEGRAM_WEBHOOK_SECRET=

# API key Gemini untuk parsing pesan pengeluaran dari chat (ambil di
# https://aistudio.google.com/apikey).
GEMINI_API_KEY=
